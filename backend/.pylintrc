[MAIN]
load-plugins=pylint.extensions.docparams

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring (handled by ruff)
    C0116,  # missing-function-docstring (handled by ruff)
    R0903,  # too-few-public-methods (Pydantic models)
    R0801,  # duplicate-code
    W0511,  # fixme/todo
    C0209,  # consider-using-f-string
    E1101,  # no-member (false positives with Pydantic)
    W0212,  # protected-access (needed in tests)

[FORMAT]
max-line-length=100
max-args=8
max-locals=20

[BASIC]
good-names=i,j,k,v,e,f,q,db,id,app

[DESIGN]
max-parents=10

[SIMILARITIES]
min-similarity-lines=6

[TYPECHECK]
ignored-modules=pydantic
ignored-classes=BaseSettings

[IMPORTS]
known-third-party=fastapi,pydantic,uvicorn,jose,passlib,supabase,httpx
