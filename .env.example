# ============================================================================
# QUIZ-FORGE ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit actual .env file to version control
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION (Backend + Frontend)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/quiz_forge

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
DEBUG=true
LOG_LEVEL=INFO
SENTRY_DSN=

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=MCQ Practice Platform
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
# - For local development, most defaults work out of the box
# - For production, ensure SECRET_KEY is a strong random string
# - Update CORS_ORIGINS to match your frontend domain
# - Configure Supabase variables for authentication to work
# - SENTRY_DSN is optional (for error tracking in production)

